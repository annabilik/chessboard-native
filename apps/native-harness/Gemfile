source 'https://rubygems.org'

# Ruby 3.3 can trigger CocoaPods 1.16.2 path corruption during project generation.
ruby '3.2.11'

# React Native's Xcode 16+ guidance pins these together.
gem 'cocoapods', '1.16.2'
gem 'xcodeproj', '1.27.0'

# Ruby 3.4 removed these libraries from the standard library.
gem 'benchmark'
gem 'bigdecimal'
gem 'logger'
gem 'mutex_m'
gem 'nkf'

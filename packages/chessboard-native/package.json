{
  "name": "@vibechess/chessboard-native",
  "version": "0.1.0-next.2",
  "description": "Controlled, rules-free React Native chessboard component",
  "type": "module",
  "source": "./src/index.ts",
  "main": "./lib/module/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/src/index.d.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./lib/typescript/src/index.d.ts",
      "react-native": "./src/index.ts",
      "import": "./lib/module/index.js",
      "default": "./lib/module/index.js"
    },
    "./pieces": {
      "types": "./lib/typescript/src/pieces/index.d.ts",
      "react-native": "./src/pieces/index.ts",
      "import": "./lib/module/pieces/index.js",
      "default": "./lib/module/pieces/index.js"
    },
    "./react-chessboard-compat": {
      "types": "./lib/typescript/src/react-chessboard-compat/index.d.ts",
      "react-native": "./src/react-chessboard-compat/index.ts",
      "import": "./lib/module/react-chessboard-compat/index.js",
      "default": "./lib/module/react-chessboard-compat/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "lib",
    "CHANGELOG.md",
    "LICENSE",
    "LICENSE.CC-BY-SA-3.0.txt",
    "NOTICE.md",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "bob build",
    "clean": "del-cli lib",
    "prepack": "bob build",
    "test": "jest --config jest.config.mjs --runInBand",
    "test:ci": "jest --config jest.config.mjs --ci --runInBand",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "keywords": [
    "chess",
    "chessboard",
    "react-native",
    "android",
    "ios"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/annabilik/chessboard-native.git",
    "directory": "packages/chessboard-native"
  },
  "author": "Anna Bilik <iamannabilik@gmail.com> (https://github.com/annabilik)",
  "license": "(MIT AND CC-BY-SA-3.0)",
  "bugs": {
    "url": "https://github.com/annabilik/chessboard-native/issues"
  },
  "homepage": "https://github.com/annabilik/chessboard-native#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "tag": "next"
  },
  "peerDependencies": {
    "react": "19.2.x",
    "react-native": "0.86.x",
    "react-native-gesture-handler": "2.32.x",
    "react-native-reanimated": "4.5.x",
    "react-native-svg": "15.15.x",
    "react-native-worklets": "0.10.x"
  },
  "devDependencies": {
    "@react-native/babel-preset": "0.86.0",
    "@react-native/jest-preset": "0.86.0",
    "@testing-library/react-native": "14.0.1",
    "@types/jest": "29.5.14",
    "@types/react": "19.2.4",
    "del-cli": "7.0.0",
    "expo": "57.0.4",
    "fast-check": "4.9.0",
    "jest": "29.7.0",
    "jest-expo": "57.0.1",
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-builder-bob": "0.43.0",
    "react-native-worklets": "0.10.0",
    "test-renderer": "1.2.0",
    "typescript": "6.0.3"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "create-react-native-library": {
    "type": "library",
    "languages": "js",
    "version": "0.63.0"
  }
}

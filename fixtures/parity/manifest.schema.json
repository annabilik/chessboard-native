{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/annabilik/chessboard-native/fixtures/parity/manifest.schema.json",
  "title": "chessboard-native upstream parity manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "schemaVersion",
    "target",
    "expectedCounts",
    "documentation",
    "entries"
  ],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "target": { "$ref": "#/definitions/target" },
    "expectedCounts": { "$ref": "#/definitions/expectedCounts" },
    "documentation": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/entry" }
    }
  },
  "definitions": {
    "sourceFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "lines", "sha256"],
      "properties": {
        "path": { "type": "string", "pattern": "^src/[A-Za-z0-9.-]+$" },
        "lines": { "type": "integer", "minimum": 1 },
        "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "namedExpression": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "expression"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "expression": { "type": "string", "minLength": 1 }
      }
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "package",
        "version",
        "tag",
        "repository",
        "commit",
        "commitTree",
        "sourceTree",
        "fixture",
        "licenseSha256",
        "ccBySaLicenseSha256",
        "provenanceSha256",
        "sourceFiles",
        "arrowOptionDefaults",
        "defaultPieceRenderers"
      ],
      "properties": {
        "package": { "const": "react-chessboard" },
        "version": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "repository": { "type": "string", "pattern": "^https://" },
        "commit": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "commitTree": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "sourceTree": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
        "fixture": { "type": "string", "minLength": 1 },
        "licenseSha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "ccBySaLicenseSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "provenanceSha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        },
        "sourceFiles": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/sourceFile" }
        },
        "arrowOptionDefaults": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/namedExpression" }
        },
        "defaultPieceRenderers": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "expectedCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sourceFiles",
        "sourceLines",
        "exports",
        "runtimeExports",
        "typeExports",
        "defaultExports",
        "options",
        "explicitOptionDefaults",
        "implicitUndefinedOptionDefaults",
        "callbackOptions",
        "styleOptions",
        "rendererOptions",
        "arrowOptionFields",
        "defaultPieceRenderers",
        "behaviors",
        "entries"
      ],
      "properties": {
        "sourceFiles": { "type": "integer", "minimum": 1 },
        "sourceLines": { "type": "integer", "minimum": 1 },
        "exports": { "type": "integer", "minimum": 1 },
        "runtimeExports": { "type": "integer", "minimum": 0 },
        "typeExports": { "type": "integer", "minimum": 0 },
        "defaultExports": { "type": "integer", "minimum": 0 },
        "options": { "type": "integer", "minimum": 1 },
        "explicitOptionDefaults": { "type": "integer", "minimum": 0 },
        "implicitUndefinedOptionDefaults": { "type": "integer", "minimum": 0 },
        "callbackOptions": { "type": "integer", "minimum": 0 },
        "styleOptions": { "type": "integer", "minimum": 0 },
        "rendererOptions": { "type": "integer", "minimum": 0 },
        "arrowOptionFields": { "type": "integer", "minimum": 0 },
        "defaultPieceRenderers": { "type": "integer", "minimum": 0 },
        "behaviors": { "type": "integer", "minimum": 1 },
        "entries": { "type": "integer", "minimum": 1 }
      }
    },
    "reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "startLine", "endLine"],
      "properties": {
        "path": { "type": "string", "pattern": "^src/[A-Za-z0-9.-]+$" },
        "startLine": { "type": "integer", "minimum": 1 },
        "endLine": { "type": "integer", "minimum": 1 }
      }
    },
    "defaultValue": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "expression"],
          "properties": {
            "kind": { "const": "expression" },
            "expression": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": { "kind": { "const": "undefined" } }
        }
      ]
    },
    "upstream": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "references"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "exportKind": { "enum": ["runtime", "type"] },
        "default": { "$ref": "#/definitions/defaultValue" },
        "members": {
          "type": "array",
          "items": { "$ref": "#/definitions/namedExpression" }
        },
        "references": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/reference" }
        }
      }
    },
    "native": {
      "type": "object",
      "additionalProperties": false,
      "required": ["surface", "symbols"],
      "properties": {
        "surface": { "enum": ["root", "compat", "internal", "none"] },
        "symbols": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "facets",
        "upstream",
        "disposition",
        "native",
        "status",
        "contractTestId",
        "compatibilityNotes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^(export|option|behavior)\\.[a-z0-9][a-z0-9.-]*$"
        },
        "kind": { "enum": ["export", "option", "behavior"] },
        "facets": {
          "type": "array",
          "uniqueItems": true,
          "items": { "enum": ["callback", "default", "renderer", "style"] }
        },
        "upstream": { "$ref": "#/definitions/upstream" },
        "disposition": { "enum": ["keep", "adapt", "redesign", "drop"] },
        "native": { "$ref": "#/definitions/native" },
        "status": { "enum": ["planned", "in-progress", "implemented"] },
        "contractTestId": {
          "type": "string",
          "pattern": "^PARITY-(EXPORT|OPTION|BEHAVIOR)-[A-Z0-9-]+$"
        },
        "rationale": { "type": "string", "minLength": 1 },
        "documentation": { "type": "string", "minLength": 1 },
        "compatibilityNotes": { "type": "string", "minLength": 1 }
      }
    }
  }
}
